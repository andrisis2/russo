  "frasi": [
    { "id": "f001", "ru": "Меня зовут Андрей.", "translit": "Minjá zavút Andréj.", "it": "Mi chiamo Andrea.", "tag": ["presentarsi", "lezione-1"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f002", "ru": "Как дела?", "translit": "Kak dilá?", "it": "Come va?", "tag": ["conversazione", "lezione-1"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f003", "ru": "Я не понимаю.", "translit": "Ja ni panimáju.", "it": "Non capisco.", "tag": ["conversazione", "lezione-1"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f004", "ru": "Это моя книга.", "translit": "Èto majá kníga.", "it": "Questo è il mio libro.", "tag": ["frasi", "lezione-2"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f005", "ru": "Где вода?", "translit": "Gdje vadá?", "it": "Dov'è l'acqua?", "tag": ["frasi", "lezione-2"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f006", "ru": "Спасибо большое!", "translit": "Spasíbo balʹšóe!", "it": "Grazie mille!", "tag": ["cortesia", "lezione-1"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f007", "ru": "Привет! Как дела?", "translit": "Privét! Kak dilá?", "it": "Ciao! Come va?", "tag": ["saluti", "video-01"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f008", "ru": "Отлично, а у тебя?", "translit": "Atlíčno, a u tibjá?", "it": "Benissimo, e tu?", "tag": ["saluti", "video-01"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f009", "ru": "Давай читать!", "translit": "Davái čitátʹ!", "it": "Dai, leggiamo!", "tag": ["espressioni", "video-01"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f010", "ru": "Здравствуйте! Как дела?", "translit": "Zdrávstvujte! Kak dilá?", "it": "Salve! Come sta? (formale)", "tag": ["saluti", "video-02"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f011", "ru": "А у вас?", "translit": "A u vas?", "it": "E Lei? (formale)", "tag": ["saluti", "video-02"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f012", "ru": "До свидания!", "translit": "Da svidánija!", "it": "Arrivederci!", "tag": ["saluti", "video-02"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f013", "ru": "Это твоя семья?", "translit": "Éto tvajá simjá?", "it": "Questa è la tua famiglia?", "tag": ["famiglia", "video-03"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f014", "ru": "Это мой брат.", "translit": "Éto moj brat.", "it": "Questo è mio fratello.", "tag": ["famiglia", "video-03"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f015", "ru": "Это моя собака.", "translit": "Éto majá sabáka.", "it": "Questo è il mio cane.", "tag": ["famiglia", "video-03"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f016", "ru": "Кто это?", "translit": "Kto éto?", "it": "Chi è questo?", "tag": ["domande", "video-04"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f017", "ru": "Это Катя. Она студентка.", "translit": "Éto Kátja. Aná studéntka.", "it": "Questa è Katia. Lei è studentessa.", "tag": ["frasi", "video-04"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f018", "ru": "Я не программист.", "translit": "Ja ni pragrammíst.", "it": "Non sono programmatore.", "tag": ["frasi", "negazione", "video-04"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f019", "ru": "Как вас зовут?", "translit": "Kak vas zavút?", "it": "Come si chiama? (formale)", "tag": ["presentarsi", "video-05"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f020", "ru": "Меня зовут Андрей.", "translit": "Minjá zavút Andréj.", "it": "Mi chiamo Andrea.", "tag": ["presentarsi", "video-05"], "difficolta": 2, "aggiunto": "2026-06-05" },
    { "id": "f021", "ru": "Очень приятно!", "translit": "Óčenʹ prijátno!", "it": "Molto piacere!", "tag": ["presentarsi", "video-05"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f022", "ru": "Что это? — Это книга.", "translit": "Što éto? — Éto kníga.", "it": "Cos'è questo? — È un libro.", "tag": ["domande", "video-05"], "difficolta": 1, "aggiunto": "2026-06-05" },
    { "id": "f023", "ru": "Где мой рюкзак? — Вот он.", "translit": "Gdje moj rjukzák? — Vot on.", "it": "Dov'è il mio zaino? — Eccolo.", "tag": ["domande", "video-05"], "difficolta": 2, "aggiunto": "2026-06-05" }
  ],
  "grammatica": [
    {
      "id": "g001",
      "titolo": "Il genere dei sostantivi",
      "spiegazione": "In russo i sostantivi hanno tre generi, riconoscibili dalla terminazione al nominativo: consonante → maschile (дом), -а/-я → femminile (вода, мама), -о/-е → neutro (окно). Eccezioni: имя (nome) finisce in -я ma è neutro.",
      "drill": [
        { "domanda": "дом", "risposta": "maschile" },
        { "domanda": "вода", "risposta": "femminile" },
        { "domanda": "окно", "risposta": "neutro" },
        { "domanda": "книга", "risposta": "femminile" },
        { "domanda": "хлеб", "risposta": "maschile" },
        { "domanda": "имя", "risposta": "neutro" }
      ]
    },
    {
      "id": "g002",
      "titolo": "I pronomi personali",
      "spiegazione": "я (io), ты (tu informale), он (lui), она (lei), оно (esso/neutro), мы (noi), вы (voi / Lei formale), они (loro). Il verbo 'essere' al presente si omette: 'Я студент' = 'Io [sono] studente'.",
      "drill": [
        { "domanda": "io", "risposta": "я" },
        { "domanda": "tu", "risposta": "ты" },
        { "domanda": "lui", "risposta": "он" },
        { "domanda": "lei", "risposta": "она" },
        { "domanda": "noi", "risposta": "мы" },
        { "domanda": "voi / Lei", "risposta": "вы" }
      ]
    },
    {
      "id": "g003",
      "titolo": "Salutare in modo informale (video L01)",
      "spiegazione": "In russo i saluti d'inizio e di fine sono DIVERSI (a differenza dell'italiano «ciao» che vale per entrambi): all'inizio si dice привет, alla fine пока. Per chiedere come va: «Как дела?» (lett. 'come [vanno gli] affari'). Si risponde отлично (benissimo), хорошо (bene), нормально/окей (così così/ok), плохо (male), e si rilancia «А у тебя?» (e tu?, lett. 'e da te?').",
      "drill": [
        { "domanda": "ciao (quando arrivi)", "risposta": "привет" },
        { "domanda": "ciao (quando vai via)", "risposta": "пока" },
        { "domanda": "come va?", "risposta": "как дела?" },
        { "domanda": "benissimo", "risposta": "отлично" },
        { "domanda": "male", "risposta": "плохо" },
        { "domanda": "e tu?", "risposta": "а у тебя?" }
      ]
    },
    {
      "id": "g004",
      "titolo": "Lettere 'iotate' Е, Ё e la Й corta (video L01)",
      "spiegazione": "Alcune lettere russe valgono DUE suoni: Е = й+э (suono 'ye', come in 'ieri'), Ё = й+о (suono 'yo', come in 'yogurt') — ed è sempre accentata. La Й è la 'i corta': una CONSONANTE (la y di 'yogurt'), da non confondere con И che è la vocale 'i'. Per pronunciarle si alza la lingua verso il palato.",
      "drill": [
        { "domanda": "Suono della lettera Е", "risposta": "ye" },
        { "domanda": "Suono della lettera Ё", "risposta": "yo" },
        { "domanda": "La Й è una...", "risposta": "consonante (i corta)" },
        { "domanda": "La И è una...", "risposta": "vocale (i)" }
      ]
    },
    {
      "id": "g005",
      "titolo": "Saluti formali vs informali (video L02)",
      "spiegazione": "Formale: здравствуйте (salve), congedo до свидания (arrivederci), e si dà del 'Lei' con вы → «А у вас?». Semi-formale/amichevole: здравствуй. Informale (amici, coetanei): привет, congedo пока, e si dà del 'tu' con ты → «А у тебя?».",
      "drill": [
        { "domanda": "salve (formale)", "risposta": "здравствуйте" },
        { "domanda": "ciao (informale)", "risposta": "привет" },
        { "domanda": "arrivederci (formale)", "risposta": "до свидания" },
        { "domanda": "ciao, congedo (informale)", "risposta": "пока" }
      ]
    },
    {
      "id": "g006",
      "titolo": "Aggettivi possessivi: мой/моя, твой/твоя (video L03)",
      "spiegazione": "Il possessivo concorda col GENERE del sostantivo, non con il possessore: maschile → мой/твой (мой папа, твой брат); femminile → моя/твоя (моя мама, твоя сестра). Attenzione: собака (cane) è femminile → моя собака.",
      "drill": [
        { "domanda": "mio (con папа, m)", "risposta": "мой" },
        { "domanda": "mia (con мама, f)", "risposta": "моя" },
        { "domanda": "tuo (con брат, m)", "risposta": "твой" },
        { "domanda": "tua (con сестра, f)", "risposta": "твоя" }
      ]
    },
    {
      "id": "g007",
      "titolo": "Cognati e suffissi: parole che già conosci (video 1000 parole)",
      "spiegazione": "Tantissime parole russe assomigliano all'italiano (tecnologia, cibo/piante, professioni/scienze, musica/sport). Inoltre i suffissi corrispondono: -zione → -ция (revolución→революция), -ale → -альный (normale→нормальный), -ivo → -ивный (sportivo→спортивный), -ico → -ический (classico→классический), -ia → -ия (magia→магия). Ricorda che la О atona si legge 'a'.",
      "drill": [
        { "domanda": "suffisso -zione (it) →", "risposta": "-ция" },
        { "domanda": "suffisso -ale (it) →", "risposta": "-альный" },
        { "domanda": "suffisso -ivo (it) →", "risposta": "-ивный" },
        { "domanda": "suffisso -ico (it) →", "risposta": "-ический" }
      ]
    },
    {
      "id": "g008",
      "titolo": "Struttura della frase: niente 'essere', negazione, domanda (video L04)",
      "spiegazione": "Al presente il russo NON usa il verbo 'essere' e NON ha articoli: «Это Паоло, он программист» = 'Questo è Paolo, lui [è] programmatore'. Per la frase negativa si mette не davanti alla parola (Она не студентка). Per fare una domanda basta l'intonazione, senza cambiare le parole (Она студентка?).",
      "drill": [
        { "domanda": "il verbo 'essere' al presente...", "risposta": "si omette" },
        { "domanda": "gli articoli (il/la/un)...", "risposta": "non esistono" },
        { "domanda": "per negare una frase si usa...", "risposta": "не + parola" },
        { "domanda": "per fare una domanda si usa...", "risposta": "solo l'intonazione" }
      ]
    },
    {
      "id": "g009",
      "titolo": "Femminile delle professioni con -ка (video L04)",
      "spiegazione": "Molte professioni formano il femminile aggiungendo -ка: студент→студентка, журналист→журналистка, спортсмен→спортсменка, футболист→футболистка. Eccezioni: учитель→учительница; alcune restano uguali per uomo e donna (врач, инженер, архитектор, дизайнер).",
      "drill": [
        { "domanda": "studentessa (da студент)", "risposta": "студентка" },
        { "domanda": "giornalista donna (da журналист)", "risposta": "журналистка" },
        { "domanda": "insegnante donna (da учитель)", "risposta": "учительница" },
        { "domanda": "medico (uomo o donna)", "risposta": "врач" }
      ]
    },
    {
      "id": "g010",
      "titolo": "Come ti chiami: Как тебя зовут? (video L05)",
      "spiegazione": "Si usa la struttura «Как + [pronome accusativo] + зовут?» (lett. 'come ti chiamano?'). Formale: Как вас зовут? — informale: Как тебя зовут? Si risponde «Меня зовут + nome». Altre persone: его зовут (lui), её зовут (lei), нас зовут (noi), их зовут (loro).",
      "drill": [
        { "domanda": "come ti chiami? (informale)", "risposta": "как тебя зовут?" },
        { "domanda": "come si chiama? (formale)", "risposta": "как вас зовут?" },
        { "domanda": "mi chiamo...", "risposta": "меня зовут..." },
        { "domanda": "lui si chiama...", "risposta": "его зовут..." }
      ]
    },
    {
      "id": "g011",
      "titolo": "Что это? vs Кто это? (video L05)",
      "spiegazione": "Кто это? = 'chi è questo?' → per persone (e animali). Что это? = 'cos'è questo?' → per oggetti, cose, piante. Nota: что si pronuncia 'što'.",
      "drill": [
        { "domanda": "студент (persona)", "risposta": "кто это?" },
        { "domanda": "лампа (oggetto)", "risposta": "что это?" },
        { "domanda": "телефон (oggetto)", "risposta": "что это?" },
        { "domanda": "собака (animale)", "risposta": "кто это?" }
      ]
    },
    {
      "id": "g012",
      "titolo": "Consonanti dure e molli (video L05)",
      "spiegazione": "Quasi tutte le consonanti possono essere dure o molli (palatalizzate, lingua sollevata verso il palato). La differenza cambia il significato: нос (naso) ≠ нёс (portava), лук (cipolla) ≠ люк (botola). Sempre DURE: ж, ш, ц. Sempre MOLLI: ч, щ, й. Una consonante è molle davanti a е, ё, я, ю e al segno molle ь.",
      "drill": [
        { "domanda": "Sempre dure:", "risposta": "ж, ш, ц" },
        { "domanda": "Sempre molli:", "risposta": "ч, щ, й" },
        { "domanda": "Ammorbidisce la consonante precedente:", "risposta": "il segno molle ь" },
        { "domanda": "Le vocali che rendono molle la consonante:", "risposta": "е, ё, я, ю" }
      ]
    }
  ]
}
